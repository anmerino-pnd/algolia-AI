# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore: NUNCA se commitea.
#
#   cp .env.example .env.local   (bash)
#   Copy-Item .env.example .env.local   (PowerShell)

# --- Algolia / Agent Studio (requeridas) ---
VITE_ALGOLIA_APP_ID=
VITE_ALGOLIA_SEARCH_KEY=        # search-only API key (read)
VITE_ALGOLIA_AGENT_ID=          # ID del agente publicado en Agent Studio

# --- Índices (opcionales; tienen default en el código) ---
VITE_ALGOLIA_INDEX=prod_productos
VITE_ALGOLIA_QS_INDEX=prod_productos_query_suggestions

# Prompt suggestions del buscador (índice dedicado que tú generas con
# scripts/seed-prompt-suggestions.mjs). Déjalo vacío si el índice no existe:
# apuntar a un índice inexistente rompe el dropdown con 404.
VITE_ALGOLIA_PROMPT_INDEX=

# --- Memoria del chat (opcional) ---
# JWT de usuario para X-Algolia-Secure-User-Token. Si está vacío, el chat corre
# SIN memoria (con feedback). Genéralo con scripts/mint-user-token.mjs.
# Caduca (default 24h); re-mintéalo o usa TOKEN_TTL_HOURS para más duración.
VITE_ALGOLIA_USER_TOKEN=
